generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "sqlite"
  url = env("DATABASE_URL")
}
model Admin {
  id Int @id @default(autoincrement())
  email String @unique
  passwordHash String
  createdAt DateTime @default(now())
}
model Product {
  id Int @id @default(autoincrement())
  slug String @unique
  name String
  category String
  price Int
  oldPrice Int?
  shortDescription String
  fullDescription String
  condition String @default("NEW")
  brand String
  model String
  year Int?
  frameSize String?
  wheelSize String?
  color String?
  specs String?
  status String @default("AVAILABLE")
  featured Boolean @default(false)
  published Boolean @default(false)
  images String @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
model Request {
  id Int @id @default(autoincrement())
  number String @unique
  token String @unique
  name String
  phone String
  email String?
  bike String?
  bikeType String
  issue String
  preferredDate String?
  contactMethod String
  status String @default("NEW")
  internalNote String?
  estimatedPrice String?
  proposedVisit String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  messages Message[]
}
model Message {
  id Int @id @default(autoincrement())
  requestId Int
  author String
  body String
  image String?
  createdAt DateTime @default(now())
  request Request @relation(fields: [requestId], references: [id], onDelete: Cascade)
}
model SiteSettings {
  id Int @id @default(1)
  phone String @default("+49 000 0000000")
  whatsapp String @default("490000000000")
  email String @default("info@meister-ok.de")
  address String @default("Адрес будет добавлен позже")
  hours String @default("Пн–Пт 09:00–18:00 · Сб 10:00–15:00")
  heroText String @default("Мы готовим велосипеды для города, спорта и приключений. Каталог скоро появится, а записаться на ремонт можно уже сейчас.")
  comingSoon Boolean @default(true)
}
